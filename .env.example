# Environment Variables for Twitter Marketing MCP

# --- Optional: Twitter API v2 Bearer Token (free tier available) ---
# Get it at: https://developer.twitter.com/en/portal/dashboard
# Free tier: 10,000 tweets/month read access
# TWITTER_BEARER_TOKEN=AAAAAAAAxxxxxxxxxx

# --- Optional: Twitter OAuth 2.0 (for posting/scheduling) ---
# TWITTER_CLIENT_ID=your-client-id
# TWITTER_CLIENT_SECRET=your-client-secret
# TWITTER_REFRESH_TOKEN=your-refresh-token

# --- Optional: HTTP/HTTPS proxy (for users in China) ---
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# --- Optional: Premium features ---
# LICENSE_KEY=your-license-key-here
# DEEPSEEK_API_KEY=sk-xxx
